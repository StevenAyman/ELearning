{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "ZiggyCreatures.Caching.Fusion": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "Database": "Server=elearning.sqlserver; Database= ELearning; User Id=sa; Password=P@ssw0rd; TrustServerCertificate=True; MultipleActiveResultsets= True",
    //"Database": "Server=localhost; Database= ELearning; Integrated Security = True; TrustServerCertificate=True; MultipleActiveResultsets= True",
    "Redis": "elearning.redis:6379"
  },
  "BackgroundJobs": {
    "Outbox": {
      "Schedule": "0/59 * * * * *",
      "BatchSize": 15
    }
  },
  "Keycloak": {
    "AuthorizationUrl": "http://localhost:18080/realms/keycloak-elearning/protocol/openid-connect/auth",
    "TokenUrl": "http://localhost:18080/realms/keycloak-elearning/protocol/openid-connect/token",
    "MetadataAddress": "http://elearning.keycloak:8080/realms/keycloak-elearning/.well-known/openid-configuration",
    "Issuer": "http://localhost:18080/realms/keycloak-elearning",
    "Audience": "account",
    "ClientId": "elearning-client"
  },
  "KeycloakOptions": {
    "BaseUrl": "http://elearning.keycloak:8080",
    "ClientId": "admin-cli",
    "GrantType": "password",
    "Username": "admin",
    "Password": "admin",
    "Realm": "keycloak-elearning",
    "RedirectUri": "http://localhost:5000/swagger/index.html",
    "ApplicationClientId": "elearning-client"
  }
}
